@page "{FromCity}/{ToCity}"
@model bookallModel

@{
    ViewData["Title"] = "Available Flights";
}

<style>

    body {
        background: #f4f7fc;
        overflow-x: hidden;
    }

    .search-header {
        background: linear-gradient(135deg,#0d6efd,#084298);
        color: white;
        padding: 40px 15px;
        border-radius: 0 0 30px 30px;
        text-align: center;
        margin-bottom: 30px;
    }

    .flight-card {
        background: white;
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        transition: .3s;
    }

        .flight-card:hover {
            transform: translateY(-4px);
        }

    .route {
        font-size: 22px;
        font-weight: bold;
    }

    .time {
        font-size: 24px;
        font-weight: bold;
        color: #0d6efd;
    }

    .price {
        font-size: 26px;
        font-weight: bold;
        color: #198754;
    }

    .flight-info {
        color: #666;
        font-size: 14px;
    }

    .flight-date {
        color: #dc3545;
        font-weight: bold;
        margin-top: 6px;
        font-size: 14px;
    }

    .book-btn {
        border-radius: 12px;
        padding: 10px 20px;
        font-weight: bold;
        width: 100%;
    }

    /* 📱 Mobile */
    @@media (max-width: 768px) {

        .route {
            font-size: 18px;
        }

        .time {
            font-size: 20px;
        }

        .price {
            font-size: 22px;
        }

        .flight-card {
            text-align: center;
        }

        .book-btn {
            margin-top: 10px;
        }
    }

</style>

<div class="search-header">

    <h1>✈️ Available Flights</h1>

    <p>
        @Model.from → @Model.To
    </p>

</div>

<div class="container">

    <div class="mb-4">

        <h4>
            Found @Model.Counter Flights
        </h4>

    </div>

    @foreach (var x in Model.f)
    {
        <div class="flight-card">

            <div class="row align-items-center">

                <!-- Departure -->

                <div class="col-md-2 text-center">

                    <div class="time">
                        @x.DepartureTime.ToString("hh:mm tt")
                    </div>

                    <div class="flight-info">
                        Departure
                    </div>

                </div>

                <!-- Route + Date -->

                <div class="col-md-4 text-center">

                    <div class="route">
                        @x.FromCity ✈️ @x.ToCity
                    </div>

                    <div class="flight-date">
                        📅 @x.DepartureTime.ToString("dddd, dd MMMM yyyy")
                    </div>

                    <div class="flight-info">
                        Direct Flight
                    </div>

                </div>

                <!-- Arrival -->

                <div class="col-md-2 text-center">

                    <div class="time">
                        @x.ArrivalTime.ToString("hh:mm tt")
                    </div>

                    <div class="flight-info">
                        Arrival
                    </div>

                </div>

                <!-- Price -->

                <div class="col-md-2 text-center">

                    <div class="price">
                        $@x.Price
                    </div>

                </div>

                <!-- Button -->
                <div class="col-md-2 text-center">

                    <a href="/Books/@x.Id"
                       class="btn btn-success book-btn">
                        Book Now
                    </a>
                    
                </div>
            </div>

        </div>
    }

</div>