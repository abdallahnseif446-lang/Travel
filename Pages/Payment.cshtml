@page "{id:int}"
@model Travel.Pages.PaymentModel

@{
    ViewData["Title"] = "Payment";
    int m = (int)Model.f.Price + 25;
}

<style>

    body {
        background: #f4f7fc;
        overflow-x: hidden;
    }

    .header {
        background: linear-gradient(135deg,#0d6efd,#084298);
        color: white;
        padding: 40px 15px;
        text-align: center;
        border-radius: 0 0 30px 30px;
        margin-bottom: 30px;
    }

    .payment-card,
    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        margin-bottom: 20px;
    }

    .form-control {
        height: 48px;
        border-radius: 12px;
    }

    .pay-btn {
        background: #198754;
        border: none;
        color: white;
        border-radius: 12px;
        padding: 14px;
        font-size: 16px;
        font-weight: bold;
        transition: .3s;
    }

        .pay-btn:hover {
            background: #157347;
        }

    .price {
        font-size: 30px;
        font-weight: bold;
        color: #198754;
    }

    .btn-home {
        background: #0d6efd;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        text-decoration: none;
        display: inline-block;
        margin-top: 25px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-home:hover {
            background: #084298;
            color: white;
        }

    /* 📱 Mobile */
    @@media (max-width: 768px) {

        .header h1 {
            font-size: 24px;
        }

        .payment-card,
        .summary-card {
            padding: 18px;
        }

        .price {
            font-size: 24px;
        }

        .form-control {
            height: 45px;
        }

        .btn-home {
            width: 100%;
        }
    }

</style>

<div class="header">
    <h1>💳 Secure Payment</h1>
    <p>Complete your booking safely</p>
</div>

<div class="container">

    <div class="row">

        <!-- LEFT SIDE -->
        <div class="col-lg-8">

            <div class="payment-card">

                <h3 class="mb-4">Card Information</h3>

                <form method="post" asp-route-id="@Model.f.Id" asp-route-y="@m">

                    <input class="form-control mb-3" required placeholder="Card Holder Name">
                    <input class="form-control mb-3" required placeholder="Card Number">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="month" required class="form-control">
                        </div>

                        <div class="col-md-6 mb-3">
                            <input type="password" required class="form-control" placeholder="CVV">
                        </div>
                    </div>

                    <input class="form-control mb-3"  required placeholder="Billing Address">
                    <button type="submit" class="btn pay-btn w-100">
                        💳 Pay Now
                    </button>

                </form>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-4">

            <div class="summary-card">

                <h3>Booking Summary</h3>

                <hr />

                <p><strong>Route:</strong> @Model.f.FromCity → @Model.f.ToCity</p>

                <p><strong>Departure:</strong> @Model.f.DepartureTime.ToString("dd MMM yyyy")</p>

                <p><strong>Time:</strong> @Model.f.DepartureTime.ToString("hh:mm tt")</p>

                <p><strong>Arrival:</strong> @Model.f.ArrivalTime.ToString("hh:mm tt")</p>

                <p><strong>Passenger:</strong> @Model.names</p>

                <hr />

                <div class="d-flex justify-content-between">
                    <span>Ticket Price</span>
                    <strong>@Model.f.Price</strong>
                </div>

                <div class="d-flex justify-content-between">
                    <span>Tax</span>
                    <strong>$25</strong>
                </div>

                <hr />

                <div class="text-center">

                    <div class="price">
                        @(Model.f.Price + 25)$
                    </div>

                    <small class="text-muted">
                        Total Amount
                    </small>

                </div>

            </div>

        </div>

    </div>
    <a href="/Books/@Model.backid" class="btn-home">
        Back
    </a>

</div>